# SCENE/STITCH public environment variables
# Set this to your final canonical URL once you have a domain.
# Example:
# NEXT_PUBLIC_SITE_URL=https://www.scene-stitch.com
NEXT_PUBLIC_SITE_URL=

# Optional author / owner name used in metadata.
NEXT_PUBLIC_SITE_AUTHOR=

# Optional footer/social profile links.
NEXT_PUBLIC_GITHUB_URL=
NEXT_PUBLIC_INSTAGRAM_URL=
NEXT_PUBLIC_X_URL=

# Optional public contact address shown on Sources / Changelog pages.
NEXT_PUBLIC_CONTACT_EMAIL=

# Optional Google Analytics 4 measurement ID.
# Example: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=

# Optional Search Console HTML tag token for URL-prefix property verification.
# Put only the content value, not the full <meta ...> tag.
GOOGLE_SITE_VERIFICATION=

# Enable Vercel Web Analytics when deployed on Vercel.
# true / false
NEXT_PUBLIC_ENABLE_VERCEL_ANALYTICS=false
